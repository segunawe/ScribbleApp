{
  "expo": {
    "name": "ScribbleApp",
    "slug": "ScribbleApp",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "scribbleapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.scribbleapp.ScribbleApp",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.scribbleapp.ScribbleApp",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.129152171516-34296cb6lp5irc6hvsfni5pk5d9aqm44"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Scribble Stories to save your drawings to Photos.",
          "savePhotosPermission": "Allow Scribble Stories to save your drawings to Photos.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-asset",
        {
          "assets": [
            "./assets/CoverPage.png",
            "./assets/Scribble_Stories_Intro_Page_1.png",
            "./assets/Scribble_Stories_Circle_Page_2.png",
            "./assets/Scribble_Stories_Circle_Practice_Page_3.png",
            "./assets/Scribble_Stories_Square_Page_4.png",
            "./assets/Scribble_Stories_Square_Practice_Page_5.png",
            "./assets/Scribble_Stories_Triangle_Page_6.png",
            "./assets/Scribble_Stories_Triangle_Practice_Page_7.png",
            "./assets/Scribble_Stories_Rectangle_Page_8.png",
            "./assets/Scribble_Stories_Rectangle_Practice_Page_9.png",
            "./assets/Scribble_Stories_Shapes_Together_Page_10.png",
            "./assets/Scribble_Stories_Shapes_Together_Practice_Page_11.png",
            "./assets/house_page1_final.png",
            "./assets/rocket_page2_final.png",
            "./assets/train_boat_page1_refined.png",
            "./assets/train_boat_page2_centered.png",
            "./assets/page1.png",
            "./assets/page2_centered.png",
            "./assets/Star_page.png",
            "./assets/heart_page.png",
            "./assets/car_page.png",
            "./assets/cloud_page.png",
            "./assets/flower_page.png",
            "./assets/robot_page.png",
            "./assets/Back_Cover.png"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b93164c9-6c75-40e1-9ffd-fbd7b09caae2"
      }
    }
  }
}
